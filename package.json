{
  "name": "long-black",
  "version": "0.12.0",
  "description": "Australian business (ABN) data → pre-joined, normalized NDJSON. One document per ABN. Built on crema.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "engines": {
    "node": ">=22.22.1"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "fixture": "./scripts/build-fixture-only.sh",
    "prepare": "husky || true"
  },
  "author": "jbejenar",
  "license": "Apache-2.0",
  "dependencies": {
    "crema": "file:../crema",
    "postgres": "^3.4.9",
    "saxes": "^6.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@dsnp/parquetjs": "^1.8.7",
    "@types/node": "^25.9.1",
    "eslint": "^10.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0",
    "vitest": "^4.1.8"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}
